{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
        "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@propertypulse/shared-types": [
        "./src/types/index.ts"
      ],
      "@propertypulse/shared-utils": [
        "./src/utils/shared-utils.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
